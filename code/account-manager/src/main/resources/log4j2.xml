<?xml version="1.0" encoding="UTF-8"?>
<Configuration name="account-manager-application" status="error">

    <Properties>
<!--        <Property name="CONSOLE_PATTERN">%date{DEFAULT} [%-5level] %X{TRACE_ID} %logger(%file:%line) - %msg%n</Property>-->
        <Property name="CONSOLE_PATTERN">%date{DEFAULT} [%-5level] %X{TRACE_ID} (%file:%line) - %msg%n</Property>
        <Property name="FILE_PATTERN">%date{DEFAULT} [%-5level] %X{TRACE_ID} (%file:%line) - %msg%n</Property>
        <Property name="MSG_PATTERN">%msg%n</Property>
    </Properties>

    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="${CONSOLE_PATTERN}"/>
        </Console>
        <Console name="DebugConsole" target="SYSTEM_OUT">
            <PatternLayout pattern="${CONSOLE_PATTERN}"/>
            <ThresholdFilter level="DEBUG" onMatch="ACCEPT" onMismatch="DENY"/>
        </Console>
        <File name="WarnFile" fileName="logs/app-warn.log">
            <PatternLayout pattern="${FILE_PATTERN}"/>
            <ThresholdFilter level="WARN" onMatch="ACCEPT" onMismatch="DENY"/>
        </File>
        <CustomLogAppender name="CustomLogAppender">
            <PatternLayout pattern="${MSG_PATTERN}"/>
            <LevelMatchFilter level="INFO" onMatch="ACCEPT" onMismatch="DENY"/>
        </CustomLogAppender>
    </Appenders>

    <Loggers>
        <Logger name="org" level="warn" additivity="false">
            <AppenderRef ref="Console"/>
        </Logger>
        <Logger name="com" level="warn" additivity="false">
            <AppenderRef ref="Console"/>
        </Logger>
<!--        <Logger name="drintau.accountmanager.desktop" level="debug" additivity="false">-->
        <Logger name="drintau.accountmanager.desktop" level="info" additivity="false">
            <AppenderRef ref="DebugConsole"/>
            <AppenderRef ref="CustomLogAppender"/>
            <AppenderRef ref="WarnFile"/>
        </Logger>
<!--        <Logger name="drintau.accountmanager.webserver" level="debug" additivity="false">-->
        <Logger name="drintau.accountmanager.webserver" level="info" additivity="false">
            <AppenderRef ref="DebugConsole"/>
            <AppenderRef ref="CustomLogAppender"/>
            <AppenderRef ref="WarnFile"/>
        </Logger>
        <Root level="info">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="WarnFile"/>
        </Root>
    </Loggers>

</Configuration>